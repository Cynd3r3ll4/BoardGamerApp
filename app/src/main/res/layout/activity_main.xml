<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/footerBar"
        android:orientation="vertical"
        android:padding="16dp">

        <include layout="@layout/app_name" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/terminwahl"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/listViewTermine"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/terminvergangen"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/listViewLetzterTermin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/footerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="?attr/colorSurfaceContainer"
        android:elevation="8dp"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.15"
            android:background="?attr/colorOnSurface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/buttonBewertung"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="40dp"
                android:clickable="true"
                android:contentDescription="@string/bewert"
                android:focusable="true"
                android:padding="8dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="?attr/colorOnSurface" />

            <ImageView
                android:id="@+id/buttonChat"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:clickable="true"
                android:contentDescription="@string/app_name"
                android:focusable="true"
                android:padding="8dp"
                android:src="@android:drawable/sym_action_chat"
                app:tint="?attr/colorOnSurface" />

        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
